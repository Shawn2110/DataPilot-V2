# DataPilot v2 — Environment Configuration
# Copy this file to .env and fill in your API key:
#   cp .env.example .env

# --- LLM Provider (pick one) ---
# Options: "cerebras" (default), "groq", "ollama"
LLM_PROVIDER=cerebras

# --- Cerebras (recommended — free, fastest, best code accuracy) ---
# Get your free API key at: https://cloud.cerebras.ai/
# Sign up → API Keys → Create New Key → paste below
CEREBRAS_API_KEY=your-cerebras-api-key-here

# --- Groq (alternative — free, fast) ---
# Get your free API key at: https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key-here

# --- Ollama (offline — local LLM, no API key needed) ---
# Install Ollama: https://ollama.com/download
# Then: ollama pull llama3.2:1b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:1b
