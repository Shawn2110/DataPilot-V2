{
  "name": "datapilot",
  "displayName": "DataPilot - AI Data Science Copilot",
  "description": "AI-powered ML pipeline that automates data cleaning, EDA, model training, and explainability inside VS Code",
  "version": "0.1.0",
  "publisher": "Shawn2110",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Machine Learning"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "datapilot.openPanel",
        "title": "DataPilot: Open Panel"
      },
      {
        "command": "datapilot.uploadDataset",
        "title": "DataPilot: Upload Dataset"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "datapilot",
          "title": "DataPilot",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "datapilot": [
        {
          "type": "webview",
          "id": "datapilot.mainView",
          "name": "DataPilot"
        }
      ]
    },
    "configuration": {
      "title": "DataPilot",
      "properties": {
        "datapilot.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter for the ML backend"
        },
        "datapilot.ollamaModel": {
          "type": "string",
          "default": "llama3.1",
          "description": "Ollama model to use (e.g., llama3.1, mistral, qwen2.5)"
        },
        "datapilot.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:ext && npm run build:webview",
    "build:ext": "node esbuild.js",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
